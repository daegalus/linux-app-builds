+
+pub fn data_path(relative: &str) -> PathBuf {
+    for root in data_roots() {
+        let candidate = root.join(relative);
+        if candidate.exists() {
+            return candidate;
+        }
+    }
+
+    data_roots()
+        .into_iter()
+        .next()
+        .unwrap_or_else(|| PathBuf::from("/usr/share"))
+        .join(relative)
+}
+
+pub fn icon_path(file: &str) -> PathBuf {
+    data_path(&format!("icons/hicolor/512x512/apps/{file}"))
+}
+
+pub fn existing_locale_dir() -> Option<PathBuf> {
+    if let Some(path) = env::var_os("ASUSCTL_LOCALE_DIR").map(PathBuf::from) {
+        return Some(path);
+    }
+
+    data_roots()
+        .into_iter()
+        .map(|root| root.join("locale"))
+        .find(|candidate| candidate.exists())
+}
